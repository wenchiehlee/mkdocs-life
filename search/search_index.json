9%BA%BC%E6%AF%8F%E5%80%8B%E4%BA%BA%E9%83%BD%E5%8F%AA%E8%81%BD%E4%BB%96%E6%83%B3%E8%81%BD%E7%9A%84/#1-selective-attention","title":"1. \u9078\u64c7\u6027\u6ce8\u610f\uff08Selective Attention\uff09","text":"<p>\u4eba\u7684\u5927\u8166\u6bcf\u5929\u63a5\u6536\u7684\u8a0a\u606f\u91cf\u6975\u5927\uff0c\u4f46\u6211\u5011\u7121\u6cd5\u8655\u7406\u5168\u90e8\uff0c\u6240\u4ee5\u6703\u81ea\u52d5\u300c\u904e\u6ffe\u300d\u6389\u548c\u81ea\u5df1\u7121\u95dc\u3001\u4e0d\u611f\u8208\u8da3\u6216\u4e0d\u7b26\u5408\u671f\u5f85\u7684\u8cc7\u8a0a\u3002\u9019\u4f7f\u5f97\u6211\u5011\u5f80\u5f80\u53ea\u5c08\u6ce8\u65bc\u90a3\u4e9b\u81ea\u5df1\u5728\u610f\u7684\u90e8\u5206\u3002</p>","tags":["\u9078\u64c7\u6027\u6ce8\u610f","\u78ba\u8a8d\u504f\u8aa4","\u8a8d\u77e5\u504f\u8aa4","\u5e95\u5c64\u908f\u8f2f"]},{"location":"blog/2025/11/%E7%82%BA%E4%BB%80%E9%BA%BC%E6%AF%8F%E5%80%8B%E4%BA%BA%E9%83%BD%E5%8F%AA%E8%81%BD%E4%BB%96%E6%83%B3%E8%81%BD%E7%9A%84/#2-cognitive-bias","title":"2. \u8a8d\u77e5\u504f\u8aa4\uff08Cognitive Bias\uff09","text":"<p>\u5176\u4e2d\u6700\u5178\u578b\u7684\u662f \u78ba\u8a8d\u504f\u8aa4\uff08Confirmation Bias\uff09\uff1a\u4eba\u5011\u50be\u5411\u5c0b\u627e\u6216\u653e\u5927\u652f\u6301\u81ea\u5df1\u89c0\u9ede\u7684\u8a0a\u606f\uff0c\u5ffd\u7565\u6216\u6de1\u5316\u8207\u4e4b\u76f8\u53cd\u7684\u8b49\u64da\u3002\u56e0\u70ba\u9019\u6a23\u80fd\u8b93\u5167\u5fc3\u66f4\u7a69\u5b9a\u3001\u4e0d\u9700\u8981\u63a8\u7ffb\u820a\u6709\u4fe1\u5ff5\u3002</p>","tags":["\u9078\u64c7\u6027\u6ce8\u610f","\u78ba\u8a8d\u504f\u8aa4","\u8a8d\u77e5\u504f\u8aa4","\u5e95\u5c64\u908f\u8f2f"]},{"location":"blog/2025/11/%E7%82%BA%E4%BB%80%E9%BA%BC%E6%AF%8F%E5%80%8B%E4%BA%BA%E9%83%BD%E5%8F%AA%E8%81%BD%E4%BB%96%E6%83%B3%E8%81%BD%E7%9A%84/#3-emotion-driven-filtering","title":"3. \u60c5\u7dd2\u8207\u5b89\u5168\u611f\u9a45\u52d5\uff08Emotion-driven Filtering\uff09","text":"<p>\u771f\u76f8\u5e38\u5e38\u5e36\u4f86\u4e0d\u5b89\u6216\u6311\u6230\uff0c\u56e0\u6b64\u4eba\u6703\u4e0b\u610f\u8b58\u5730\u8ff4\u907f\u90a3\u4e9b\u8b93\u81ea\u5df1\u7126\u616e\u3001\u6050\u61fc\u6216\u75db\u82e6\u7684\u8a0a\u606f\uff0c\u800c\u50be\u5411\u63a5\u53d7\u80fd\u8b93\u81ea\u5df1\u300c\u8212\u670d\u4e00\u9ede\u300d\u7684\u8072\u97f3\u3002</p>","tags":["\u9078\u64c7\u6027\u6ce8\u610f","\u78ba\u8a8d\u504f\u8aa4","\u8a8d\u77e5\u504f\u8aa4","\u5e95\u5c64\u908f\u8f2f"]},{"location":"blog/2025/11/%E7%82%BA%E4%BB%80%E9%BA%BC%E6%AF%8F%E5%80%8B%E4%BA%BA%E9%83%BD%E5%8F%AA%E8%81%BD%E4%BB%96%E6%83%B3%E8%81%BD%E7%9A%84/#4-bounded-rationality","title":"4. \u6709\u9650\u7406\u6027\uff08Bounded Rationality\uff09","text":"<p>\u4eba\u7684\u6c7a\u7b56\u4e26\u4e0d\u662f\u5168\u77e5\u5168\u80fd\uff0c\u800c\u662f\u57fa\u65bc\u6709\u9650\u7684\u77e5\u8b58\u3001\u7d93\u9a57\u8207\u8cc7\u6e90\u505a\u51fa\u7684\u3002\u9019\u5c0e\u81f4\u6211\u5011\u300c\u9078\u64c7\u6027\u5438\u6536\u300d\u8a0a\u606f\uff0c\u628a\u80fd\u7b26\u5408\u7576\u4e0b\u8a8d\u77e5\u6846\u67b6\u7684\u6771\u897f\u7559\u4e0b\u4f86\uff0c\u5176\u4ed6\u5c31\u6392\u9664\u6389\u3002</p>","tags":["\u9078\u64c7\u6027\u6ce8\u610f","\u78ba\u8a8d\u504f\u8aa4","\u8a8d\u77e5\u504f\u8aa4","\u5e95\u5c64\u908f\u8f2f"]},{"location":"blog/2025/11/%E7%82%BA%E4%BB%80%E9%BA%BC%E6%AF%8F%E5%80%8B%E4%BA%BA%E9%83%BD%E5%8F%AA%E8%81%BD%E4%BB%96%E6%83%B3%E8%81%BD%E7%9A%84/#5-social-validation","title":"5. \u793e\u6703\u8a8d\u540c\uff08Social Validation\uff09","text":"<p>\u5728\u7fa4\u9ad4\u4e92\u52d5\u4e2d\uff0c\u4eba\u66f4\u5bb9\u6613\u63a5\u53d7\u81ea\u5df1\u8eab\u908a\u4eba\u6216\u7fa4\u9ad4\u5167\u7684\u4e3b\u6d41\u8072\u97f3\u3002\u56e0\u70ba\u9019\u4e0d\u50c5\u7b26\u5408\u300c\u60f3\u807d\u7684\u300d\uff0c\u9084\u80fd\u5e36\u4f86\u6b78\u5c6c\u611f\uff0c\u6e1b\u5c11\u8207\u7fa4\u9ad4\u885d\u7a81\u7684\u58d3\u529b\u3002</p> <p>\u7e3d\u7d50\uff1a\u5e95\u5c64\u908f\u8f2f\u53ef\u4ee5\u6fc3\u7e2e\u70ba\u4e00\u53e5\u8a71</p> <p>\u4eba\u4e26\u4e0d\u662f\u8ffd\u6c42\u771f\u76f8\uff0c\u800c\u662f\u8ffd\u6c42\u5fc3\u7406\u8212\u9069\u8207\u8a8d\u77e5\u7a69\u5b9a\u3002</p>","tags":["\u9078\u64c7\u6027\u6ce8\u610f","\u78ba\u8a8d\u504f\u8aa4","\u8a8d\u77e5\u504f\u8aa4","\u5e95\u5c64\u908f\u8f2f"]},{"location":"blog/2025/11/","title":"2025/11","text":""},{"location":"blog/category/%E7%94%9F%E6%B4%BB/","title":"\u751f\u6d3b","text":""},{"location":"blog/category/%E5%BF%83%E7%90%86%E5%AD%B8/","title":"\u5fc3\u7406\u5b78","text":""},{"location":"tag/","title":"Tags","text":"<p>Tip</p> <p>\u4ee5\u4e0b\u662f\u76f8\u95dc\u6a19\u7c64\u7684\u5217\u8868</p>"},{"location":"tag/#_1","title":"\u5e95\u5c64\u908f\u8f2f","text":"<ul> <li>\u70ba\u4ec0\u9ebc\"\u6bcf\u500b\u4eba\u90fd\u53ea\u807d\u4ed6\u60f3\u807d\u7684\"\uff1f</li> </ul>"},{"location":"tag/#_2","title":"\u78ba\u8a8d\u504f\u8aa4","text":"<ul> <li>\u70ba\u4ec0\u9ebc\"\u6bcf\u500b\u4eba\u90fd\u53ea\u807d\u4ed6\u60f3\u807d\u7684\"\uff1f</li> </ul>"},{"location":"tag/#_3","title":"\u8a8d\u77e5\u504f\u8aa4","text":"<ul> <li>\u70ba\u4ec0\u9ebc\"\u6bcf\u500b\u4eba\u90fd\u53ea\u807d\u4ed6\u60f3\u807d\u7684\"\uff1f</li> </ul>"},{"location":"tag/#_4","title":"\u9078\u64c7\u6027\u6ce8\u610f","text":"<ul> <li>\u70ba\u4ec0\u9ebc\"\u6bcf\u500b\u4eba\u90fd\u53ea\u807d\u4ed6\u60f3\u807d\u7684\"\uff1f</li> </ul>"}]}